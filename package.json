{
  "name": "forgegames",
  "version": "1.0.0",
  "description": "A ForgeScript extension that brings interactive games to your Discord bot",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "docgen": "node dist/docgen",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,md}\"",
    "test": "node ./dist/__tests__/index.js"
  },
  "keywords": [
    "forgescript",
    "discord",
    "games",
    "trivia",
    "wordle",
    "math"
  ],
  "author": "tryforge",
  "license": "GPL-3.0",
  "packageManager": "pnpm@10.13.1",
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@tryforge/forgescript": "github:tryforge/ForgeScript#dev",
    "@types/node": "^24.12.0",
    "discord.js": "^14.25.1",
    "prettier": "^3.8.1",
    "tiny-typed-emitter": "^2.1.0",
    "typescript": "^5.9.3"
  }
}