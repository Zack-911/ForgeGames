[{"name":"$gameAddScore","description":"Adds (or subtracts) points to a player in the current game. Returns the new score.","version":"1.0.0","brackets":true,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"userID","description":"Target user","type":"User","required":true,"rest":false},{"name":"points","description":"Points to add (can be negative)","type":"Number","required":true,"rest":false}],"output":["Number"],"category":"game"},{"name":"$gameExists","description":"Returns true if any game session (waiting or active) exists in the current channel.","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild to check","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel to check","type":"Channel","required":true,"rest":false}],"output":["Boolean"],"category":"game"},{"name":"$gameGetData","description":"Retrieves a value from the game session's data store.","version":"1.0.0","brackets":true,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"key","description":"Data key to retrieve","type":"String","required":true,"rest":false}],"output":["String"],"category":"game"},{"name":"$gameInfo","description":"Returns a JSON object with information about the current game session.","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"field","description":"Specific field to return (id|type|status|difficulty|playerCount|hostId|startedAt|timeoutMs)","type":"String","required":true,"rest":false}],"output":["Json"],"category":"game"},{"name":"$gameIsActive","description":"Returns true if there is an active (running) game in the given channel.","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild to check","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel to check","type":"Channel","required":true,"rest":false}],"output":["Boolean"],"category":"game"},{"name":"$gameLeaderboard","description":"Returns a JSON array of players sorted by score (highest first).","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"limit","description":"How many entries to return (default: all)","type":"Number","required":false,"rest":false}],"output":["Json"],"category":"game"},{"name":"$gamePlayerExists","description":"Returns true if a user has joined the current game session.","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"userID","description":"User to check (defaults to caller)","type":"User","required":false,"rest":false}],"output":["Boolean"],"category":"game"},{"name":"$gamePlayerScore","description":"Returns the score of a specific player in the current game session.","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"userID","description":"The user to look up (defaults to command caller)","type":"User","required":false,"rest":false}],"output":["Number"],"category":"game"},{"name":"$gameSetData","description":"Stores a key-value pair in the game session's data store.","version":"1.0.0","brackets":true,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"key","description":"Data key","type":"String","required":true,"rest":false},{"name":"value","description":"Data value","type":"String","required":true,"rest":false}],"output":["Boolean"],"category":"game"},{"name":"$gameHangmanGuess","description":"Guesses a single letter in Hangman. Returns JSON: { letter, correct, wrongCount, maxWrong, masked, guessed, won, lost, correctWord }. masked is an array e.g. [\"h\",null,\"n\",\"g\",\"m\",\"a\",\"n\"] — null for unguessed letters. correctWord is only revealed on win or loss.","version":"1.0.0","brackets":true,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"letter","description":"Single letter to guess","type":"String","required":true,"rest":false},{"name":"userID","description":"Override user ID","type":"User","required":false,"rest":false}],"output":["Json"],"category":"hangman"},{"name":"$gameNewHangman","description":"Starts a Hangman round. Returns JSON: { wordLength, maxWrong, masked, guessed, wrongCount }. masked is an array of revealed letters and nulls e.g. [null,\"a\",null,null].","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false}],"output":["Json"],"category":"hangman"},{"name":"$gameMathAnswer","description":"Submits a numeric answer to the current math question. Returns JSON: { correct, answer, correctAnswer, pointsEarned, score }.","version":"1.0.0","brackets":true,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"answer","description":"The numeric answer","type":"Number","required":true,"rest":false},{"name":"userID","description":"Override user ID","type":"User","required":false,"rest":false}],"output":["Json"],"category":"math"},{"name":"$gameNewMath","description":"Generates a new math question for the session and returns it as JSON.","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false}],"output":["Json"],"category":"math"},{"name":"$gameNewRps","description":"Initialises a Rock-Paper-Scissors round. Returns JSON: { challenger, opponent, isBotOpponent }. Omit opponentID to play against the bot.","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"opponentID","description":"Opponent user (omit for bot play)","type":"User","required":false,"rest":false}],"output":["Json"],"category":"rps"},{"name":"$gameRpsChoice","description":"Submits a rock/paper/scissors choice. When both players have chosen, returns a result JSON.","version":"1.0.0","brackets":true,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"choice","description":"rock | paper | scissors","type":"String","required":true,"rest":false},{"name":"userID","description":"Override user ID","type":"User","required":false,"rest":false}],"output":["Json"],"category":"rps"},{"name":"$gameNewScramble","description":"Generates a scrambled word for players to unscramble. Returns JSON: { scrambled, wordLength, points, difficulty }. The correct answer is never revealed until someone solves it or the game ends.","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false}],"output":["Json"],"category":"scramble"},{"name":"$gameScrambleAnswer","description":"Submits an answer to the current scramble. Returns JSON: { correct, answer, correctWord, pointsEarned, score }. correctWord is revealed on correct answer.","version":"1.0.0","brackets":true,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"answer","description":"Unscrambled word attempt","type":"String","required":true,"rest":false},{"name":"userID","description":"Override user ID","type":"User","required":false,"rest":false}],"output":["Json"],"category":"scramble"},{"name":"$gameCreate","description":"Creates a new game session in the given channel. Returns the session ID or an error if one already exists.","version":"1.0.0","brackets":true,"unwrap":true,"args":[{"name":"type","description":"Game type: trivia | wordle | math | hangman | scramble | tictactoe | rps","type":"String","required":true,"rest":false},{"name":"guildID","description":"Guild to create the session in","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel to create the session in","type":"Channel","required":true,"rest":false},{"name":"difficulty","description":"Difficulty: easy | medium | hard (default: medium)","type":"String","required":false,"rest":false},{"name":"timeoutSeconds","description":"Seconds before auto-expire (default: 30)","type":"Number","required":false,"rest":false},{"name":"maxPlayers","description":"Max players allowed (default: 10)","type":"Number","required":false,"rest":false}],"output":["String"],"category":"session"},{"name":"$gameEnd","description":"Ends the active game session in the given channel.","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false}],"output":["Boolean"],"category":"session"},{"name":"$gameJoin","description":"Joins the active game session in the given channel.","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"userID","description":"User joining (defaults to command caller)","type":"User","required":false,"rest":false}],"output":["Boolean"],"category":"session"},{"name":"$gameLeave","description":"Removes a player from the active game session.","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"userID","description":"User to remove (defaults to command caller)","type":"User","required":false,"rest":false}],"output":["Boolean"],"category":"session"},{"name":"$gameStart","description":"Starts the game session and begins the timer.","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false}],"output":["Boolean"],"category":"session"},{"name":"$gameNewTicTacToe","description":"Sets up a Tic-Tac-Toe board. The host is X, the challenged player is O. Returns JSON: { board, playerX, playerO, currentTurn }. board is a 9-element array of \"X\", \"O\", or null (index 0 = top-left, 8 = bottom-right).","version":"1.0.0","brackets":true,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"opponentID","description":"User ID of the O player","type":"User","required":true,"rest":false}],"output":["Json"],"category":"tictactoe"},{"name":"$gameTicTacToeMove","description":"Makes a move in Tic-Tac-Toe. Position is 1–9 (top-left to bottom-right). Returns JSON: { board, position, symbol, winner, draw, nextTurn, playerX, playerO }. board is a 9-element array of \"X\", \"O\", or null. winner is a userId or null. draw is boolean.","version":"1.0.0","brackets":true,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"position","description":"Cell 1–9 (top-left to bottom-right)","type":"Number","required":true,"rest":false},{"name":"userID","description":"Override user ID","type":"User","required":false,"rest":false}],"output":["Json"],"category":"tictactoe"},{"name":"$gameNewTrivia","description":"Loads a new trivia question into the session and returns it as JSON. Sets a per-question timeout.","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"category","description":"Filter by category (general|science|history|geography|sports|entertainment|technology)","type":"String","required":false,"rest":false}],"output":["Json"],"category":"trivia"},{"name":"$gameTriviaAnswer","description":"Submits an answer to the current trivia question. Returns JSON: { correct, answer, correctAnswer, pointsEarned, score }.","version":"1.0.0","brackets":true,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"answer","description":"The player's answer","type":"String","required":true,"rest":false},{"name":"userID","description":"Override user ID","type":"User","required":false,"rest":false}],"output":["Json"],"category":"trivia"},{"name":"$gameEvent","description":"Returns data from the current ForgeGames event payload as JSON. Use inside game event handlers.","version":"1.0.0","unwrap":false,"output":["Json"],"category":"util"},{"name":"$gameGuildSessions","description":"Returns a JSON array of all active game sessions in the given guild.","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild to query (defaults to current guild)","type":"Guild","required":true,"rest":false}],"output":["Json"],"category":"util"},{"name":"$gameStats","description":"Returns statistics for a player in the current game session as JSON.","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"userID","description":"User to look up (defaults to caller)","type":"User","required":false,"rest":false}],"output":["Json"],"category":"util"},{"name":"$gameNewWordle","description":"Starts a new Wordle round. Returns JSON with the max guesses allowed and difficulty.","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false}],"output":["Json"],"category":"wordle"},{"name":"$gameWordleGuess","description":"Submits a 5-letter Wordle guess. Returns JSON: { guess, tiles, tileArray, guessNumber, guessesLeft, won, lost, correctWord }. tiles is a string of emoji (🟩🟨⬛). tileArray is [\"correct\",\"present\",\"absent\",...] for custom rendering. correctWord is only revealed on win or loss.","version":"1.0.0","brackets":true,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false},{"name":"guess","description":"A 5-letter word","type":"String","required":true,"rest":false},{"name":"userID","description":"Override user ID","type":"User","required":false,"rest":false}],"output":["Json"],"category":"wordle"},{"name":"$gameWordleGuessCount","description":"Returns JSON with guesses used, guesses left, and the full guess+tile history.","version":"1.0.0","brackets":false,"unwrap":true,"args":[{"name":"guildID","description":"Guild of the session","type":"Guild","required":true,"rest":false},{"name":"channelID","description":"Channel of the session","type":"Channel","required":true,"rest":false}],"output":["Json"],"category":"wordle"}]